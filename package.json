{
  "name": "moonbet-pwa",
  "version": "1.0.0",
  "description": "MoonBet PWA with iOS and Android install + Push Notifications",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "generate-keys": "node -e \"const wp=require('web-push');const k=wp.generateVAPIDKeys();console.log('VAPID_PUBLIC_KEY='+k.publicKey);console.log('VAPID_PRIVATE_KEY='+k.privateKey);\"",
    "generate-icons": "node generate-icons.js",
    "setup": "npm install && npm run generate-keys && npm run generate-icons"
  },
  "dependencies": {
    "canvas": "^2.11.2",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "sharp": "^0.34.5",
    "web-push": "^3.6.7"
  }
}
